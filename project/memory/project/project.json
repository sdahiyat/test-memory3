{
  "schemaVersion": "cofabric.memory.project.v1",
  "name": "mindful-journal",
  "oneLineDescription": "A journaling and mood tracking web app with AI-generated insights",
  "whatItIs": "A journaling + mood tracking web app with AI-generated reflections.",
  "stack": [
    {
      "name": "@supabase/supabase-js",
      "version": "^2.38.0",
      "purpose": "database and auth"
    },
    {
      "name": "next",
      "version": "^14.0.0",
      "purpose": "React framework"
    },
    {
      "name": "openai",
      "version": "^4.20.0",
      "purpose": "AI insights generation"
    },
    {
      "name": "react",
      "version": "^18.2.0",
      "purpose": "UI framework"
    },
    {
      "name": "stripe",
      "version": "^14.5.0",
      "purpose": "payment processing"
    }
  ],
  "externalIntegrations": [
    {
      "service": "Supabase",
      "envVars": [
        "NEXT_PUBLIC_SUPABASE_URL",
        "NEXT_PUBLIC_SUPABASE_ANON_KEY",
        "SUPABASE_SERVICE_ROLE_KEY"
      ],
      "clientLocation": "src/lib/supabase.ts"
    },
    {
      "service": "OpenAI",
      "envVars": [
        "OPENAI_API_KEY"
      ],
      "clientLocation": "src/lib/openai.ts"
    },
    {
      "service": "Stripe",
      "envVars": [
        "STRIPE_SECRET_KEY",
        "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY",
        "STRIPE_WEBHOOK_SECRET"
      ],
      "clientLocation": "src/lib/stripe.ts"
    }
  ],
  "coreUserFlows": [
    "Users create, edit, and delete journal entries",
    "Users log their daily mood",
    "Users view timeline of entries and moods",
    "Users receive AI-generated insights (paid feature)",
    "Users search entries and tags"
  ],
  "outOfScope": []
}